aws_region  = "ap-south-1"
aws_profile = "nilkanthaws9"

cluster_name       = "jerney-eks-prod"
environment        = "prod"
cluster_version    = "1.35"

vpc_cidr             = "10.2.0.0/16"
public_subnet_cidrs  = ["10.2.0.0/24", "10.2.1.0/24"]
private_subnet_cidrs = ["10.2.10.0/24", "10.2.11.0/24"]
az_count             = 2 # NAT gateways scale with AZ count

node_instance_types = ["t3.large"]
capacity_type       = "ON_DEMAND"
min_node_count      = 3
max_node_count      = 8
disk_size_gb        = 50

# If the API endpoint is public, restrict it to known CIDRs (office/VPN),
# or set endpoint_public_access = false for a private-only endpoint.
endpoint_public_access = true
public_access_cidrs    = ["203.0.113.0/24"]

# NAT HA
single_nat_gateway = false
